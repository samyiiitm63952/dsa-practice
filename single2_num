#include<iostream>
#include<vector>
using namespace std;
int single2(vector<int>arr){
    map<int,int>mpp;

    for(int i=0;i<arr.size();i++){
        mpp[arr[i]]++;
    }
    auto (it:mpp){
        if(auto it.second<3){
            return it.first;
        }
    }
    return -1;
}
class Solution {
public:
    int singleNumber(vector<int>& nums) {
        int ans=0;
        for(int bi=0;bi<32;bi++){
            int cnt=0;
            for(int i=0;i<nums.size();i++){
                if(nums[i] & (1<<bi)){
                    cnt++;
                }
            }
            if(cnt%3==1){
               ans= ans | (1<<bi);
            }

        }
        return ans;
    }
};